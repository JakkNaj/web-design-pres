---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { brand } from '@/data/brand';
import { getPageBySlug } from '@/lib/content';

type Project = CollectionEntry<'projects'>;

const pages = await getCollection('pages');
const projects = await getCollection('projects');
const home = getPageBySlug(pages, 'home');

const projectBySlug = (slug: string) => projects.find((project) => project.data.slug === slug);
const imageByUrlPart = (part: string, fallback: string) =>
  home?.data.images.find((image) => image.url.includes(part))?.url ?? fallback;
const linkByUrlPart = (part: string, fallback: string) =>
  home?.data.links.find((link) => link.url.includes(part))?.url ?? fallback;

const grandPrix = projectBySlug('dalnice-d1-stavba-0136-rikovice-prerov');
const heroImage = grandPrix?.data.image ?? {
  url: 'https://ceskadopravnistavba.cz/wp-content/uploads/2026/06/06-STRABAG-D1-Rikovice-scaled.jpg',
  alt: 'Dálnice D1, stavba 0136 Říkovice-Přerov'
};

const featuredProjects = [
  {
    slug: 'lavka-pres-vltavu-hluboka-nad-vltavou',
    category: 'Dopravní stavby ostatní · 2025'
  },
  {
    slug: 'rekonstrukce-ozubnicove-trati-tanvald-korenov',
    category: 'Kolejové stavby · 2025',
    summary:
      'Obnova jediné ozubnicové trati v ČR s ocelovými pražci ve tvaru Y a novou Abtovou ozubnicí.'
  },
  {
    slug: 'vyuziti-site-5g-pro-novou-sluzbu-c-its-k-regulaci-vjezdu-do-historickeho-centra-brna',
    category: 'Technologie a inovace · 2025',
    title: 'Síť 5G a C-ITS pro regulaci vjezdů do centra Brna',
    summary:
      'Zásuvné bezpečnostní sloupky řízené v reálném čase přes 5G a kooperativní dopravní systémy.'
  },
  {
    slug: 'd35-janov-opatovec',
    category: 'Silniční · 2025',
    title: 'D35 Janov - Opatovec',
    summary: 'Nový úsek dálnice D35 doplňuje hlavní silniční tah mezi východními Čechami a Moravou.'
  }
]
  .map((row) => ({ ...row, project: projectBySlug(row.slug) }))
  .filter((row): row is typeof row & { project: Project } => Boolean(row.project));

const categories = [
  {
    index: '01',
    slug: 'dopravni-stavby-dalnicni',
    icon: 'motorway',
    title: 'Dopravní stavby dálniční',
    count: '6 staveb'
  },
  {
    index: '02',
    slug: 'dopravni-stavby-silnicni',
    icon: 'road',
    title: 'Dopravní stavby silniční',
    count: '2 stavby'
  },
  {
    index: '03',
    slug: 'dopravni-stavby-kolejove-zelenicni-a-tramvajove',
    icon: 'rail',
    title: 'Dopravní stavby kolejové, železniční a tramvajové',
    count: '5 staveb'
  },
  {
    index: '04',
    slug: 'dopravni-stavby-vodni-a-vodohospodarske',
    icon: 'water',
    title: 'Dopravní stavby vodní a vodohospodářské',
    count: '4 stavby'
  },
  {
    index: '05',
    slug: 'dopravni-stavby-ostatni',
    icon: 'bridge',
    title: 'Dopravní stavby ostatní',
    count: '3 stavby'
  },
  {
    index: '06',
    slug: 'technologie-a-inovace-v-doprave',
    icon: 'chip',
    title: 'Technologie a inovace v dopravě',
    count: '3 stavby'
  },
  {
    index: '07',
    slug: 'projekty-dopravnich-staveb',
    icon: 'project',
    title: 'Projekty dopravních staveb',
    count: '4 projekty'
  }
];

const purposes = [
  'Profesionální prezentace oborů českého dopravního stavitelství a inženýrství.',
  'Podpora rozvoje moderního stavitelství dbajícího na efektivitu i šetrnost k životnímu prostředí.',
  'Podpora Dopravní politiky ČR a iniciativ SMART CITY a PRŮMYSL 4.0.',
  'Podpora implementace metody BIM jako nástroje pro zefektivnění výstavby.'
];

const cnnLogo = imageByUrlPart(
  'CPN_LOGO_V1_rgb',
  'https://ceskadopravnistavba.cz/wp-content/uploads/2025/05/CPN_LOGO_V1_rgb-768x269.png'
);
const e15Logo = imageByUrlPart(
  'e15_logo_barva',
  'https://ceskadopravnistavba.cz/wp-content/uploads/2025/04/e15_logo_barva-768x460.png'
);

const mediaCards = [
  {
    logo: cnnLogo,
    logoAlt: 'CNN Prima News',
    type: 'Reportáž',
    title: 'Česká dopravní stavba 2024 zná své vítěze',
    text: 'Mezi příštími i expresní železnice mezi Prahou a středními Čechami.',
    href: linkByUrlPart('cnn.iprima.cz', 'https://cnn.iprima.cz/')
  },
  {
    logo: e15Logo,
    logoAlt: 'E15',
    type: 'Tisková zpráva',
    title: 'Soutěž zná své vítěze',
    text: 'Nejvyšší ocenění získalo sedm významných projektů dopravního stavitelství.',
    href:
      'https://www.e15.cz/tiskove-zpravy/soutez-ceska-dopravni-stavba-a-technologie-zna-sve-viteze-nejvyssi-oceneni-ziskalo-sedm-vyznamnych-projektu-1425620'
  }
];

const excerpt = (text: string, fallback: string) => {
  const value = (text || fallback).replace(/\s+/g, ' ').trim();
  return value.length > 150 ? `${value.slice(0, 147).trim()}...` : value;
};
---

<BaseLayout title={brand.name} description={home?.data.seoDescription}>
  <section class="news-strip" aria-label="Aktualita">
    <span class="news-badge">AKTUÁLNĚ</span>
    <span>Známe vítězné projekty za rok 2025 - vyhlášen 23. ročník soutěže.</span>
    <a href="/vitezne-projekty/">Zobrazit výsledky <span aria-hidden="true">→</span></a>
  </section>

  <section class="hero">
    <div class="hero-copy">
      <div class="eyebrow">CELOSTÁTNÍ SOUTĚŽ · VÍCE NEŽ 20 LET</div>
      <h1>Česká dopravní stavba <span>&amp; technologie</span></h1>
      <p>
        Celostátní soutěž, která každoročně oceňuje nejvýznamnější projekty dopravních staveb,
        technologie a výrazné inovace v oboru.
      </p>
      <div class="button-row">
        <a class="button" href="/vitezne-projekty/">Vítězné projekty 2025 <span aria-hidden="true">→</span></a>
        <a class="button button--secondary" href="/o-soutezi/">Více o soutěži</a>
      </div>
    </div>

    <div class="hero-media">
      <a class="hero-image" href={grandPrix ? `/stavba/${grandPrix.data.slug}/` : '/vitezne-projekty/'}>
        <img src={heroImage.url} alt={heroImage.alt} loading="eager" />
        <div class="image-caption">
          <div>Oceněná stavba 2025 · Grand Prix</div>
          <strong>Dálnice D1, stavba 0136 Říkovice-Přerov</strong>
        </div>
      </a>
    </div>
  </section>

  <section class="stats-row" aria-label="Základní údaje o soutěži">
    <div>
      <strong>23.</strong>
      <span>ročník soutěže</span>
    </div>
    <div>
      <strong>7</strong>
      <span>kategorií + studentská</span>
    </div>
    <div>
      <strong>20<em>+</em></strong>
      <span>let tradice</span>
    </div>
    <div>
      <strong>30+</strong>
      <span>oceněných staveb</span>
    </div>
  </section>

  <section class="split-section" id="o-soutezi">
    <div class="section-index">
      <span>01</span>
      <strong>O soutěži</strong>
    </div>
    <div class="section-body">
      <h2>Ocenění, které dvacet let formuje obor</h2>
      <p class="lead">
        Cílem soutěže je přispívat k profesionální prezentaci oborů českého dopravního stavitelství
        a oceňovat technické návrhy, které dbají nejen na inovativnost a odbornou propracovanost, ale
        i ekonomické a ekologické parametry.
      </p>
      <p class="organizer"><span>Organizátor</span> Svaz podnikatelů ve stavebnictví - od roku 2024</p>

      <div class="numbered-list">
        {
          purposes.map((item, index) => (
            <div class="numbered-row">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <p>{item}</p>
            </div>
          ))
        }
      </div>

      <a class="button" href="/o-soutezi/">Více o soutěži <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <section class="split-section" id="kategorie">
    <div class="section-index">
      <span>02</span>
      <strong>Kategorie</strong>
    </div>
    <div class="section-body">
      <h2>Sedm soutěžních kategorií</h2>
      <div class="category-list">
        {
          categories.map((category) => (
            <a class="category-row" href={`/oceneni/${category.slug}/`}>
              <span class="category-index">{category.index}</span>
              <span class="category-icon" aria-hidden="true">
                {category.icon === 'motorway' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M4 21 L6 3" />
                    <path d="M11 21 V3" />
                    <path d="M13 21 V3" />
                    <path d="M20 21 L18 3" />
                  </svg>
                )}
                {category.icon === 'road' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M7 21 L10 3" />
                    <path d="M17 21 L14 3" />
                    <path d="M12 6 v3 M12 12 v3" />
                  </svg>
                )}
                {category.icon === 'rail' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M8 3 V21 M16 3 V21 M5 7 H19 M5 12 H19 M5 17 H19" />
                  </svg>
                )}
                {category.icon === 'water' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M3 8 q3 -2.5 6 0 t6 0 t6 0 M3 13 q3 -2.5 6 0 t6 0 t6 0 M3 18 q3 -2.5 6 0 t6 0 t6 0" />
                  </svg>
                )}
                {category.icon === 'bridge' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M3 16 h18 M3 16 v-3 M21 16 v-3 M6 16 a6 6 0 0 1 12 0 M3 12 h18" />
                  </svg>
                )}
                {category.icon === 'chip' && (
                  <svg viewBox="0 0 24 24">
                    <rect x="7" y="7" width="10" height="10" rx="1.5" />
                    <path d="M10 7 V4 M14 7 V4 M10 20 V17 M14 20 V17 M7 10 H4 M7 14 H4 M20 10 H17 M20 14 H17" />
                  </svg>
                )}
                {category.icon === 'project' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M5 19 L19 19 L5 8 Z" />
                    <path d="M5 14 L10 19" />
                  </svg>
                )}
              </span>
              <span class="category-title">{category.title}</span>
              <span class="category-count">{category.count}</span>
              <span class="category-arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
        <a class="category-row category-row--student" href="/studentska-cena/">
          <span class="category-index">★</span>
          <span class="category-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 3 L3 8 L12 13 L21 8 Z" />
              <path d="M7 10.5 V15 C7 15 9 17 12 17 C15 17 17 15 17 15 V10.5" />
            </svg>
          </span>
          <span class="category-title">Studentská cena</span>
          <span class="category-count">zvláštní</span>
          <span class="category-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <section class="split-section" id="media">
    <div class="section-index">
      <span>03</span>
      <strong>Napsali o nás</strong>
    </div>
    <div class="media-grid">
      {
        mediaCards.map((card) => (
          <a class="media-card" href={card.href}>
            <div class="media-logo">
              <img src={card.logo} alt={card.logoAlt} loading="lazy" />
            </div>
            <div class="card-label">{card.type}</div>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="projects-section" id="vitezove">
    <div class="center-heading">
      <div class="eyebrow">04 · Vítězné projekty</div>
      <h2>Výběr z ročníku 2025</h2>
      <a href="/vitezne-projekty/">Celý archiv →</a>
    </div>

    <div class="project-grid">
      {
        featuredProjects.map(({ project, category, title, summary }) => (
          <a class="project-card" href={`/stavba/${project.data.slug}/`}>
            {project.data.image && (
              <div class="project-image">
                <img src={project.data.image.url} alt={project.data.image.alt || project.data.title} loading="lazy" />
              </div>
            )}
            <div class="card-label">{category}</div>
            <h3>{title ?? project.data.title}</h3>
            <p>{summary ?? excerpt(project.data.summary, brand.description)}</p>
          </a>
        ))
      }
    </div>

    <div class="enrollment-panel">
      <div>
        <div class="panel-kicker">Přihlašování 24. ročníku · zatím neotevřeno</div>
        <h2>Přihlašování dalšího ročníku zatím není spuštěné</h2>
        <p>
          Sledujte spuštění 24. ročníku. Zatím si projděte oceněné projekty z právě uzavřeného
          ročníku 2025.
        </p>
      </div>
      <a class="button" href="/vitezne-projekty/">Celý archiv vítězů →</a>
    </div>
  </section>
</BaseLayout>
