---
import '../../styles/global.css';

interface Props {
  to: string;
  title?: string;
}

const { to, title = 'Stránka byla přesunuta' } = Astro.props;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={to} />
    <title>{title}</title>
  </head>
  <body>
    <main class="redirect-page">
      <section class="redirect-page__box">
        <h1>{title}</h1>
        <p>Obsah najdete na nové adrese.</p>
        <p><a class="button" href={to}>Pokračovat</a></p>
      </section>
    </main>
  </body>
</html>
