---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  href?: string;
  linkLabel?: string;
  tone?: 'teal' | 'blue' | 'red';
}

const { eyebrow, title, description, href, linkLabel = 'Více', tone = 'teal' } = Astro.props;
---

<div class="section-heading" data-reveal>
  <div>
    <p class:list={['eyebrow', { 'eyebrow--blue': tone === 'blue', 'eyebrow--red': tone === 'red' }]}>{eyebrow}</p>
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </div>
  {href && <a class="text-link" href={href}>{linkLabel}<svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9M8.5 4.5 12 8l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg></a>}
</div>
