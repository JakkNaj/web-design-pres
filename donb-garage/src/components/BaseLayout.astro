---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "DON B Diagnostic Garage - diagnostika, autoelektrika a servis moderních vozů v Plané nad Lužnicí."
} = Astro.props;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0C0C" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      const navToggle = document.querySelector("[data-nav-toggle]");
      const navLinks = document.querySelector("[data-nav-links]");

      navToggle?.addEventListener("click", () => {
        const expanded = navToggle.getAttribute("aria-expanded") === "true";
        navToggle.setAttribute("aria-expanded", String(!expanded));
        navLinks?.toggleAttribute("data-open", !expanded);
      });

      navLinks?.addEventListener("click", (event) => {
        if (event.target instanceof HTMLAnchorElement) {
          navToggle?.setAttribute("aria-expanded", "false");
          navLinks.removeAttribute("data-open");
        }
      });

      document.querySelectorAll("[data-faq-button]").forEach((button) => {
        button.addEventListener("click", () => {
          const item = button.closest("[data-faq-item]");
          const isOpen = button.getAttribute("aria-expanded") === "true";
          button.setAttribute("aria-expanded", String(!isOpen));
          item?.toggleAttribute("data-open", !isOpen);
        });
      });

      const contactForm = document.querySelector("[data-contact-form]");

      if (contactForm instanceof HTMLFormElement) {
        const queryParams = new URLSearchParams(window.location.search);
        const issueType = queryParams.get("typ");
        const phoneField = contactForm.querySelector("[data-contact-phone]");
        const emailField = contactForm.querySelector("[data-contact-email]");
        const messageField = contactForm.querySelector("[data-contact-message]");
        const honeypotField = contactForm.querySelector("[data-honeypot]");
        const clean = (value) => String(value || "").trim();
        const hasValue = (field) => field instanceof HTMLInputElement && clean(field.value);
        const isValidPhone = (value) => {
          const trimmed = clean(value);

          if (!trimmed) {
            return true;
          }

          const digits = trimmed.replace(/\D/g, "");

          return /^[+\d][\d\s().-]{6,23}$/.test(trimmed) && digits.length >= 9 && digits.length <= 15;
        };

        if (issueType && messageField instanceof HTMLTextAreaElement && !messageField.value.trim()) {
          const messageTemplate = [
            `Typ problému: ${issueType}`,
            "",
            "Vůz:",
            "Rok výroby / motorizace:",
            "Najeto kilometrů:",
            "Kdy se problém objevuje:",
            "Svítí kontrolka nebo hláška:",
            "Co už bylo kontrolováno nebo opravováno:",
            "Další poznámky:"
          ].join("\n");

          messageField.value = messageTemplate;
          messageField.dataset.prefilledTemplate = messageTemplate;
        }

        const syncContactValidity = () => {
          if (phoneField instanceof HTMLInputElement) {
            phoneField.setCustomValidity("");
          }

          if (emailField instanceof HTMLInputElement) {
            emailField.setCustomValidity("");
          }

          if (messageField instanceof HTMLTextAreaElement) {
            messageField.setCustomValidity("");
          }

          if (phoneField instanceof HTMLInputElement && emailField instanceof HTMLInputElement && !hasValue(phoneField) && !hasValue(emailField)) {
            phoneField.setCustomValidity("Vyplňte telefon nebo e-mail, abychom vás mohli kontaktovat.");
          }

          if (phoneField instanceof HTMLInputElement && phoneField.value.trim() && !isValidPhone(phoneField.value)) {
            phoneField.setCustomValidity("Zadejte telefon ve správném formátu, například +420 777 852 398.");
          }

          if (emailField instanceof HTMLInputElement && emailField.value.trim() && emailField.validity.typeMismatch) {
            emailField.setCustomValidity("Zadejte platnou e-mailovou adresu.");
          }

          if (
            messageField instanceof HTMLTextAreaElement &&
            messageField.dataset.prefilledTemplate &&
            clean(messageField.value) === clean(messageField.dataset.prefilledTemplate)
          ) {
            messageField.setCustomValidity("Doplňte prosím popis vozu a závady.");
          }
        };

        const validateContactForm = () => {
          syncContactValidity();
          return contactForm.checkValidity();
        };

        [phoneField, emailField, messageField].forEach((field) => {
          field?.addEventListener("input", syncContactValidity);
          field?.addEventListener("change", syncContactValidity);
        });
        contactForm.addEventListener("invalid", syncContactValidity, true);

        contactForm.addEventListener("submit", (event) => {
          event.preventDefault();

          if (honeypotField instanceof HTMLInputElement && honeypotField.value.trim()) {
            return;
          }

          if (!validateContactForm()) {
            contactForm.reportValidity();
            return;
          }

          const formData = new FormData(contactForm);
          const name = clean(formData.get("name"));
          const phone = clean(formData.get("phone"));
          const email = clean(formData.get("email"));
          const message = clean(formData.get("message"));
          const submittedAt = new Date().toLocaleString("cs-CZ", {
            dateStyle: "medium",
            timeStyle: "short",
            timeZone: "Europe/Prague"
          });
          const body = [
            "Poptávka z webu DON B Diagnostic Garage",
            "----------------------------------------",
            `Odesláno: ${submittedAt}`,
            `Stránka: ${window.location.href}`,
            "",
            "Kontakt",
            "-------",
            `Jméno: ${name}`,
            `Telefon: ${phone || "neuvedeno"}`,
            `E-mail: ${email || "neuvedeno"}`,
            "",
            "Vůz a popis závady",
            "------------------",
            message
          ].join("\n");
          const subjectSuffix = name ? ` - ${name}` : "";
          const subject = encodeURIComponent(`Poptávka z webu DON B${subjectSuffix}`);

          window.location.href = `mailto:info@donbgarage.cz?subject=${subject}&body=${encodeURIComponent(body)}`;
        });
      }
    </script>
  </body>
</html>
