---
---

<form
  class="contact-form"
  action="mailto:info@donbgarage.cz?subject=Popt%C3%A1vka%20z%20webu%20DON%20B%20Diagnostic%20Garage"
  method="post"
  enctype="text/plain"
  accept-charset="UTF-8"
  data-contact-form
>
  <div class="form-honeypot" aria-hidden="true">
    <label for="contact-company">Firma</label>
    <input id="contact-company" name="company" type="text" autocomplete="off" tabindex="-1" data-honeypot />
  </div>
  <div class="form-grid">
    <label>
      <span>Jméno</span>
      <input name="name" type="text" autocomplete="name" required minlength="2" maxlength="80" placeholder="Vaše jméno" />
    </label>
    <label>
      <span>Telefon</span>
      <input name="phone" type="tel" autocomplete="tel" inputmode="tel" maxlength="24" placeholder="+420 777 852 398" data-contact-phone />
    </label>
  </div>
  <label>
    <span>E-mail</span>
    <input name="email" type="email" autocomplete="email" inputmode="email" maxlength="120" placeholder="vas@email.cz" data-contact-email />
  </label>
  <label>
    <span>Vůz a popis závady</span>
    <textarea name="message" rows="9" required minlength="20" maxlength="2000" placeholder="Značka a model vozu, co se děje, kdy se to objevuje..." data-contact-message></textarea>
  </label>
  <button class="button button--primary" type="submit">Odeslat zprávu</button>
</form>
