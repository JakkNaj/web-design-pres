---
import { Image } from 'astro:assets';
import heroImage from '../../assets/brand/hc-ricany-hero.png';
import Button from '../ui/Button.astro';
---
<section id="top" class="hero">
  <Image class="hero__image" src={heroImage} alt="Hokejista v tmavém dresu na ledě" widths={[800, 1200, 1600]} sizes="100vw" loading="eager" />
  <div class="hero__shade"></div>
  <div class="container hero__content">
    <p class="hero__label">HC Říčany · led, který spojuje</p>
    <h1 class="display">Hokej patří<br />do <span>Říčan</span></h1>
    <p class="hero__lead">Klub pro malé i velké hráče. Pro každého, kdo má chuť vyjet na led a být součástí týmu.</p>
    <div class="hero__actions"><Button href="#nabor">Chci na led</Button><Button href="#aktuality" tone="dark">Co je nového</Button></div>
  </div>
</section>
<style>
  .hero { position: relative; z-index: 1; min-height: min(900px, 100svh); display: flex; align-items: end; overflow: visible; background: #10191f; isolation: isolate; }
  .hero__image { position: absolute; inset: 0; width: 100%; height: calc(100% + 5.5rem); object-fit: cover; object-position: 64% center; z-index: -2; pointer-events: none; }
  .hero__shade { position: absolute; inset: 0; height: calc(100% + 5.5rem); z-index: -1; pointer-events: none; background: linear-gradient(90deg, rgba(6,12,16,.96) 0%, rgba(6,12,16,.78) 35%, rgba(6,12,16,.12) 70%), linear-gradient(0deg, rgba(6,12,16,.72), transparent 45%); }
  .hero__content { position: relative; z-index: 2; padding-top: 6rem; padding-bottom: clamp(2.5rem, 7vw, 6rem); transform: translateY(clamp(.5rem, 1.5vw, 1.5rem)); }
  .hero__label { margin: 0 0 1rem; color: var(--accent); font-weight: 850; font-size: .76rem; letter-spacing: .13em; text-transform: uppercase; }
  h1 { max-width: 760px; margin: 0; font-size: clamp(4.2rem, 10vw, 9.5rem); text-shadow: 0 6px 20px rgba(0,0,0,.28); } h1 span { color: var(--accent); }
  .hero__lead { max-width: 33rem; margin: 1.4rem 0 1.75rem; color: #d6e0e1; font-size: clamp(1rem, 1.8vw, 1.2rem); }
  .hero__actions { display: flex; flex-wrap: wrap; gap: .75rem; }
  @media (min-width: 821px) and (max-height: 900px) { .hero { min-height: calc(100svh - 8rem); } .hero__content { padding-top: 3rem; padding-bottom: 6rem; transform: none; } h1 { font-size: clamp(3.7rem, 7vw, 6.6rem); } .hero__label { margin-bottom: .65rem; } .hero__lead { margin: .8rem 0 1rem; font-size: 1rem; } }
  @media (max-width: 900px) {
    .hero { min-height: auto; display: block; }
    .hero__content { padding-top: 8rem; padding-bottom: clamp(2.75rem, 9vw, 4.5rem); transform: none; }
    .hero__label { margin-bottom: .65rem; }
  }
  @media (max-width: 680px) {
    .hero__content { padding-top: 8rem; padding-bottom: clamp(2rem, 8vw, 3rem); }
    .hero__image { object-position: 72% center; }
    .hero__shade { background: linear-gradient(90deg, rgba(6,12,16,.9), rgba(6,12,16,.42)), linear-gradient(0deg, rgba(6,12,16,.9), transparent 50%); }
  }
</style>
