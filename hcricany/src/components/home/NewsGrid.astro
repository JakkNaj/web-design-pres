---
import type { CollectionEntry } from 'astro:content';
import Badge from '../ui/Badge.astro';
import SectionHeading from '../ui/SectionHeading.astro';
interface Props { news: CollectionEntry<'news'>[]; }
const { news } = Astro.props;
const formatDate = (date: Date) => new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(date);
---
<section id="aktuality" class="section section--light"><div class="container"><SectionHeading title="Aktuality" eyebrow="Z klubu" href="#aktuality" />
  <div class="news-grid">{news.map((item, index) => <article class:list={['news', { 'news--featured': index === 0 }]}>
    <div class="news__image" style={`background-image: url(${item.data.image})`}></div><div class="news__content"><Badge tone={index === 0 ? 'red' : 'dark'}>{item.data.category}</Badge><p class="news__date">{formatDate(item.data.date)}</p><h3>{item.data.title}</h3><p>{item.data.excerpt}</p><a class="text-link" href="#kontakt">Zjistit více</a></div>
  </article>)}</div>
</div></section>
<style>
  .news-grid { display: grid; grid-template-columns: 1.15fr .85fr .85fr; gap: 1rem; }
  .news { display: flex; flex-direction: column; border: 1px solid #c7d3d6; background: white; } .news__image { min-height: 180px; background-position: center; background-size: cover; filter: saturate(.75); }
  .news--featured .news__image { min-height: 290px; } .news__content { padding: 1.25rem; } .news__date { margin: 1rem 0 .35rem; color: #63747a; font-size: .75rem; font-weight: 800; }
  h3 { margin: 0; font-family: var(--display); font-size: clamp(1.55rem, 2.6vw, 2.25rem); font-weight: 400; letter-spacing: .025em; line-height: .98; text-transform: uppercase; } .news__content > p:not(.news__date) { color: #4a5c62; font-size: .9rem; }
  @media (max-width: 850px) { .news-grid { grid-template-columns: 1fr; } .news--featured .news__image, .news__image { min-height: 220px; } }
</style>
