---
const actions = [
  ['Nábor', 'První bruslení'], ['Tréninky', 'Kdy jsme na ledě'], ['Aktuality', 'Co je v klubu'], ['Rozpis ledu', 'Týdenní přehled'], ['Kontakt', 'Ozvěte se nám'],
];
---
<section id="klub" class="actions" aria-label="Rychlé odkazy">
  <div class="container actions__grid">
    {actions.map(([title, description], index) => <a id={index === 0 ? 'nabor' : undefined} href={index === 0 ? '#nabor' : index === 1 || index === 3 ? '#rozpis' : index === 2 ? '#aktuality' : '#kontakt'} class="action"><span class="action__number">0{index + 1}</span><strong>{title}</strong><small>{description}</small><b aria-hidden="true">↗</b></a>)}
  </div>
</section>
<style>
  .actions { position: relative; z-index: 2; margin-top: -1rem; margin-bottom: -3.25rem; }
  .actions__grid { display: grid; grid-template-columns: repeat(5, 1fr); box-shadow: var(--shadow); }
  .action { position: relative; min-height: 154px; padding: 1.15rem; display: flex; flex-direction: column; border: 1px solid var(--line); background: var(--ink-soft); transition: background-color 180ms ease, color 180ms ease; }
  .action__number { color: var(--accent); font-size: .72rem; font-weight: 900; letter-spacing: .1em; }
  .action strong { margin-top: auto; font-family: var(--display); font-size: 1.9rem; font-weight: 400; letter-spacing: .04em; text-transform: uppercase; }
  .action small { color: #abc0c3; font-size: .72rem; font-weight: 650; }
  .action b { position: absolute; top: 1rem; right: 1rem; color: var(--signal); font-size: 1.3rem; }
  @media (hover: hover) { .action:hover { background: var(--accent); color: var(--ink); } .action:hover .action__number, .action:hover b { color: var(--ink); } .action:hover small { color: var(--ink-soft); } }
  @media (min-width: 821px) and (max-height: 900px) { .action { min-height: 136px; padding: 1rem; } .action strong { font-size: 1.7rem; } }
  @media (max-width: 820px) { .actions { margin-top: 0; margin-bottom: -2rem; } .actions__grid { grid-template-columns: repeat(2, 1fr); } .action:last-child { grid-column: span 2; } }
  @media (max-width: 460px) { .actions__grid { grid-template-columns: 1fr; } .action:last-child { grid-column: auto; } }
</style>
