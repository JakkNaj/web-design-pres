---
import { getCollection } from 'astro:content';
import { navItems } from '../../lib/siteData';

interface Props {
  clubName: string;
  email: string;
  address: string;
  facebook: string;
  hidePartnerStrip?: boolean;
}

const { clubName, email, address, facebook, hidePartnerStrip = false } = Astro.props;
const partnersCollection = await getCollection('partners');
const partners = partnersCollection[0]?.data ?? [];
---

<footer class="site-footer">
  {!hidePartnerStrip && (
    <div class="site-shell site-footer__partners" data-reveal>
      <span>Partneři klubu</span>
      <div>
        {partners.map((partner) => (
          <a href={partner.website} target="_blank" rel="noreferrer" aria-label={partner.name}>
            {partner.image ? (
              <img src={partner.image} alt={partner.name} loading="lazy" />
            ) : (
              <strong>{partner.logo}</strong>
            )}
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="site-shell site-footer__grid">
    <div class="site-footer__about" data-reveal>
      <a class="site-footer__brand" href="/">
        <span><img src="/images/brand/hc-comsys-ricany-logo.webp" alt="HC Com-Sys Říčany" width="300" height="296" /></span>
        <strong>HC ŘÍČANY</strong>
      </a>
      <p>Hokejový klub pro děti, mládež a hráče z Říčan a okolí. Trénujeme v COM-SYS ICE ARENĚ.</p>
      <div class="site-footer__socials">
        <a href={facebook} target="_blank" rel="noreferrer">Facebook</a>
      </div>
    </div>

    <nav class="site-footer__links" aria-label="Navigace v patičce" data-reveal>
      <h2>Navigace</h2>
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="site-footer__contact" data-reveal>
      <h2>Kontakt</h2>
      <p>{clubName}<br />{address}</p>
      <a href={`mailto:${email}`}>{email}</a>
      <a href="tel:+420604123456">+420 604 123 456</a>
    </div>

    <div class="site-footer__links" data-reveal>
      <h2>Partneři & odkazy</h2>
      <a href="https://www.comsys.cz">COM-SYS Ice Arena</a>
      <a href="http://www.golmansketreninky.cz">Gólmanské tréninky AGA</a>
      <a href="https://www.pojdhrathokej.cz">Pojď hrát hokej</a>
      <a href="https://www.ceskyhokej.cz">Pískej hokej</a>
      <a href="https://www.ricany.cz">Město Říčany</a>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="site-shell">
      <span>© {new Date().getFullYear()} {clubName} - všechna práva vyhrazena</span>
      <span><a href="/admin/">Administrace</a> · <a href="/dokumenty/zpracovani-osobnich-udaju/">GDPR</a></span>
    </div>
  </div>
</footer>
