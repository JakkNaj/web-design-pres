---
import { navItems } from '../../lib/siteData';

interface Props {
  active?: string;
}

const { active = '' } = Astro.props;
---

<header class="site-header" data-site-header>
  <div class="site-shell site-header__inner">
    <a class="site-header__brand" href="/" aria-label="HC Říčany - úvod">
      <span class="site-header__logo">
        <img src="/images/brand/hc-comsys-ricany-logo.webp" alt="HC Com-Sys Říčany" width="300" height="296" />
      </span>
      <span class="site-header__name">
        <strong>HC ŘÍČANY</strong>
        <span>HOKEJOVÝ KLUB</span>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Hlavní navigace">
      {navItems.map((item) => (
        <a class:list={{ 'is-active': item.label === active }} href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a class="site-header__cta" href="/nabor/">Chci začít s hokejem</a>

    <button class="site-header__toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" data-menu-toggle>
      Menu
    </button>
  </div>

  <nav id="mobile-menu" class="site-header__mobile" aria-label="Mobilní navigace" hidden data-mobile-menu>
    {navItems.map((item) => (
      <a class:list={{ 'is-active': item.label === active }} href={item.href}>{item.label}</a>
    ))}
    <a class="site-header__mobile-cta" href="/nabor/">Chci začít s hokejem</a>
  </nav>
</header>

<script>
  const menuButton = document.querySelector('[data-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');

  menuButton?.addEventListener('click', () => {
    const expanded = menuButton.getAttribute('aria-expanded') === 'true';
    menuButton.setAttribute('aria-expanded', String(!expanded));
    if (mobileMenu instanceof HTMLElement) {
      mobileMenu.hidden = expanded;
    }
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuButton?.setAttribute('aria-expanded', 'false');
      if (mobileMenu instanceof HTMLElement) {
        mobileMenu.hidden = true;
      }
    });
  });
</script>
