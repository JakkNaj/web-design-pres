---
interface EventItem {
  title: string;
  date: Date;
  location: string;
  type: string;
  link: string;
}

interface Props {
  events: EventItem[];
}

const { events } = Astro.props;
---

<div class="event-list">
  {events.map((event) => {
    const day = String(event.date.getDate()).padStart(2, '0');
    const month = String(event.date.getMonth() + 1).padStart(2, '0');
    return (
      <a class="event-card" href={event.link} data-reveal>
        <span class="event-date">
          <strong>{day}</strong>
          <span>{month}</span>
        </span>
        <span>
          <b>{event.title}</b>
          <span>{event.location}</span>
        </span>
      </a>
    );
  })}
</div>
