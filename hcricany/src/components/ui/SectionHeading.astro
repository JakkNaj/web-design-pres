---
interface Props { title: string; eyebrow?: string; href?: string; linkLabel?: string; }
const { title, eyebrow, href, linkLabel = 'Zobrazit vše' } = Astro.props;
---

<div class="section-heading">
  <div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2 class="display">{title}</h2>
  </div>
  {href && <a class="text-link" href={href}>{linkLabel}</a>}
</div>
