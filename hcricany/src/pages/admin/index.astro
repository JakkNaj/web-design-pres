---
// UI-only Decap showcase. The mock login gates the editor visually; the CMS uses
// Decap's test backend and does not write to GitHub.
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>HC Říčany · redakce</title>
    <style>
      :root {
        --black: #0f1114;
        --black-soft: #14171b;
        --steel: #5a6470;
        --muted: #8a939c;
        --ice: #f0f3f5;
        --line: #e3e8eb;
        --white: #ffffff;
        --red: #c8102e;
        --red-dark: #a50d26;
        --teal: #2f8f88;
        --teal-bright: #52b3ac;
        --font-body: Barlow, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-display: "Barlow Condensed", Barlow, ui-sans-serif, system-ui, sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        background:
          linear-gradient(135deg, rgba(47, 143, 136, 0.12), transparent 34%),
          var(--black);
        color: var(--black-soft);
        font-family: var(--font-body);
      }

      .mock-login {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 1.5rem;
      }

      .mock-login[hidden],
      .cms-root[hidden] {
        display: none;
      }

      .mock-login__panel {
        width: min(100%, 440px);
        padding: clamp(1.35rem, 4vw, 2rem);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 6px;
        background: var(--white);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
      }

      .mock-login__brand {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 1.4rem;
      }

      .mock-login__brand span {
        display: grid;
        place-items: center;
        width: 54px;
        height: 54px;
        border-radius: 6px;
        background: var(--ice);
      }

      .mock-login__brand img {
        width: 42px;
        height: 42px;
        object-fit: contain;
      }

      .mock-login__brand strong {
        display: block;
        font-family: var(--font-display);
        font-size: 1.65rem;
        line-height: 1;
      }

      .mock-login__brand small {
        color: var(--steel);
        font-weight: 600;
      }

      .mock-login h1 {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(2.2rem, 8vw, 2.85rem);
        line-height: 1.02;
      }

      .mock-login p {
        margin: 0.7rem 0 1.35rem;
        color: var(--steel);
        line-height: 1.55;
      }

      .mock-login label {
        display: grid;
        gap: 0.35rem;
        margin-bottom: 0.85rem;
        color: var(--steel);
        font-size: 0.9rem;
        font-weight: 700;
      }

      .mock-login input {
        width: 100%;
        border: 1px solid #d4dbe0;
        border-radius: 4px;
        padding: 0.78rem 0.9rem;
        color: var(--black-soft);
        font: inherit;
      }

      .mock-login input:focus {
        border-color: var(--teal);
        outline: 3px solid rgba(82, 179, 172, 0.24);
      }

      .mock-login__honeypot {
        position: absolute;
        left: -10000px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }

      .mock-login button {
        width: 100%;
        min-height: 46px;
        border: 0;
        border-radius: 4px;
        background: var(--red);
        color: var(--white);
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        transition:
          background-color 220ms ease,
          transform 220ms ease;
      }

      .mock-login button:hover {
        background: var(--red-dark);
        transform: translateY(-1px);
      }

      .mock-login__note,
      .mock-login__error {
        display: block;
        margin-top: 0.85rem;
        color: var(--muted);
        font-size: 0.83rem;
        line-height: 1.45;
      }

      .mock-login__error {
        color: var(--red-dark);
        font-weight: 700;
      }

      body.is-cms-active {
        background: var(--white);
      }

      .cms-root {
        display: none;
      }
    </style>
  </head>
  <body>
    <section class="mock-login" data-mock-login>
      <form class="mock-login__panel" data-mock-form>
        <div class="mock-login__brand">
          <span><img src="../images/brand/hc-comsys-ricany-logo.webp" alt="HC Říčany" width="300" height="296" /></span>
          <div>
            <strong>HC ŘÍČANY</strong>
            <small>redakční rozhraní</small>
          </div>
        </div>
        <h1>Ukázka CMS</h1>
        <p>Toto je demo přihlášení pro prezentaci administrace. Vyplňte libovolný e-mail a heslo, data se nikam neodesílají.</p>
        <label>
          E-mail
          <input name="email" type="email" autocomplete="email" placeholder="redakce@hcricany.cz" required />
        </label>
        <label>
          Heslo
          <input name="password" type="password" autocomplete="current-password" placeholder="libovolné heslo" required />
        </label>
        <label class="mock-login__honeypot" aria-hidden="true">
          Web
          <input name="website" tabindex="-1" autocomplete="off" />
        </label>
        <button type="submit">Vstoupit do CMS</button>
        <span class="mock-login__note">Demo režim: změny se uloží jen v prohlížeči a nevytvoří commit do GitHubu.</span>
        <span class="mock-login__error" data-mock-error hidden>Přihlášení se nezdařilo.</span>
      </form>
    </section>
    <main class="cms-root" data-cms-root hidden></main>
    <script>
      import CMS from 'decap-cms-app';
      import { createElement as h } from 'react';
      import type { ReactNode } from 'react';

      type DemoWindow = Window & {
        repoFiles?: Record<string, unknown>;
      };

      type PreviewEntry = {
        getIn: (path: string[], fallback?: unknown) => unknown;
      };

      type NewsPreviewProps = {
        entry: PreviewEntry;
        widgetFor: (name: string) => ReactNode;
      };

      type GalleryPreviewProps = {
        entry: PreviewEntry;
      };

      const demoWindow = window as DemoWindow;
      const login = document.querySelector<HTMLElement>('[data-mock-login]');
      const form = document.querySelector<HTMLFormElement>('[data-mock-form]');
      const error = document.querySelector<HTMLElement>('[data-mock-error]');
      const cmsRoot = document.querySelector<HTMLElement>('[data-cms-root]');
      const sessionKey = 'hc-ricany-cms-demo';
      let cmsStarted = false;

      const siteBasePath = new URL('../', window.location.href).pathname;

      const formatDate = (value: unknown) => {
        const date = value ? new Date(String(value)) : null;
        if (!date || Number.isNaN(date.valueOf())) return 'Datum aktuality';

        return new Intl.DateTimeFormat('cs-CZ', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        }).format(date);
      };

      const formatAlbumDate = (value: unknown) => {
        const date = value ? new Date(String(value)) : null;
        if (!date || Number.isNaN(date.valueOf())) return 'Datum alba';

        return new Intl.DateTimeFormat('cs-CZ', {
          day: 'numeric',
          month: 'numeric',
          year: 'numeric',
        }).format(date);
      };

      const getField = (entry: PreviewEntry, field: string, fallback = '') => {
        const value = entry.getIn(['data', field]);
        return typeof value === 'string' && value.trim() ? value : fallback;
      };

      const toPlainRecord = (value: unknown): Record<string, unknown> | null => {
        if (!value || typeof value !== 'object') return null;

        const withToJs = value as { toJS?: () => unknown };
        const plain = typeof withToJs.toJS === 'function' ? withToJs.toJS() : value;

        if (!plain || typeof plain !== 'object' || Array.isArray(plain)) return null;
        return plain as Record<string, unknown>;
      };

      const getListItems = (value: unknown) => {
        if (!value) return [];

        if (Array.isArray(value)) {
          return value.map(toPlainRecord).filter((item): item is Record<string, unknown> => Boolean(item));
        }

        if (typeof value === 'object') {
          const withToJs = value as { toJS?: () => unknown };
          if (typeof withToJs.toJS === 'function') return getListItems(withToJs.toJS());

          const maybeList = value as { size?: unknown; get?: (index: number) => unknown };
          const getItem = maybeList.get;
          if (typeof maybeList.size === 'number' && typeof getItem === 'function') {
            return Array.from({ length: maybeList.size }, (_, index) => getItem(index))
              .map(toPlainRecord)
              .filter((item): item is Record<string, unknown> => Boolean(item));
          }
        }

        return [];
      };

      const getRecordString = (record: Record<string, unknown> | undefined, field: string, fallback = '') => {
        const value = record?.[field];
        return typeof value === 'string' && value.trim() ? value : fallback;
      };

      const formatPhotoCount = (count: number) => {
        if (count === 1) return '1 fotka';
        if (count > 1 && count < 5) return `${count} fotky`;
        return `${count} fotek`;
      };

      const getImageUrl = (value: string) => {
        if (!value) return `${siteBasePath}images/navrh01/ricany_kids.jpg`;
        if (/^(https?:|data:|blob:)/.test(value)) return value;
        if (value.startsWith(siteBasePath)) return value;
        if (value.startsWith('/')) return `${siteBasePath}${value.slice(1)}`;
        return `${siteBasePath}${value}`;
      };

      CMS.registerPreviewStyle(
        `
          .cms-news-preview {
            min-height: 100%;
            background: #ffffff;
            color: #14171b;
            font-family: Barlow, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
          }

          .cms-news-preview * {
            box-sizing: border-box;
          }

          .cms-news-preview__inner {
            max-width: 820px;
            margin: 0 auto;
            padding: 42px 28px 70px;
          }

          .cms-news-preview__breadcrumbs {
            margin-bottom: 1rem;
            color: #5f6872;
            font-size: 0.9rem;
            font-weight: 700;
          }

          .cms-news-preview__breadcrumbs span {
            color: #c8102e;
          }

          .cms-news-preview__meta {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.8rem;
            margin-bottom: 0.9rem;
          }

          .cms-news-preview__tag {
            display: inline-flex;
            align-items: center;
            min-height: 28px;
            padding: 0.35rem 0.65rem;
            border-radius: 4px;
            background: #c8102e;
            color: #ffffff;
            font-size: 0.74rem;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
          }

          .cms-news-preview time {
            color: #5f6872;
            font-weight: 700;
          }

          .cms-news-preview h1 {
            margin: 0.6rem 0 1rem;
            color: #14171b;
            font-family: "Barlow Condensed", Barlow, ui-sans-serif, system-ui, sans-serif;
            font-size: clamp(2.4rem, 6vw, 3rem);
            font-weight: 800;
            line-height: 0.98;
          }

          .cms-news-preview__lead {
            margin: 0 0 1.35rem;
            color: #3a424b;
            font-size: 1.15rem;
            font-weight: 500;
            line-height: 1.55;
          }

          .cms-news-preview__image {
            display: block;
            width: 100%;
            height: min(52vw, 440px);
            min-height: 260px;
            object-fit: cover;
            border-radius: 6px;
          }

          .cms-news-preview__caption {
            display: block;
            margin-top: 0.5rem;
            color: #6d7580;
            font-size: 0.84rem;
          }

          .cms-news-preview__body {
            margin-top: 1.35rem;
            color: #3a424b;
            font-size: 1rem;
            line-height: 1.75;
          }

          .cms-news-preview__body p {
            margin: 0 0 1rem;
          }

          .cms-news-preview__info {
            margin-top: 1.35rem;
            padding: 1.25rem 1.45rem;
            border-radius: 6px;
            background: #f0f3f5;
          }

          .cms-news-preview__info h2 {
            margin: 0 0 0.7rem;
            color: #14171b;
            font-family: "Barlow Condensed", Barlow, ui-sans-serif, system-ui, sans-serif;
            font-size: 1.7rem;
            line-height: 1;
          }

          .cms-news-preview__info-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.65rem 1rem;
            color: #3a424b;
          }

          .cms-news-preview__info-grid strong {
            color: #14171b;
          }

          @media (max-width: 720px) {
            .cms-news-preview__inner {
              padding: 30px 18px 52px;
            }

            .cms-news-preview__info-grid {
              grid-template-columns: 1fr;
            }
          }

          .cms-gallery-preview {
            min-height: 100%;
            background: #ffffff;
            color: #14171b;
            font-family: Barlow, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            line-height: 1.55;
          }

          .cms-gallery-preview * {
            box-sizing: border-box;
          }

          .cms-gallery-preview img {
            display: block;
            max-width: 100%;
          }

          .cms-gallery-preview a {
            color: inherit;
            text-decoration: none;
          }

          .cms-gallery-preview__inner {
            width: 100%;
            max-width: 1304px;
            margin: 0 auto;
            padding: 42px 32px 70px;
          }

          .cms-gallery-preview__eyebrow {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            margin: 0 0 0.55rem;
            color: #5a6470;
            font-family: "Barlow Condensed", Barlow, ui-sans-serif, system-ui, sans-serif;
            font-size: 0.94rem;
            font-weight: 600;
            letter-spacing: 0.18em;
            text-transform: uppercase;
          }

          .cms-gallery-preview__eyebrow::before {
            content: "";
            width: 22px;
            height: 3px;
            background: #c8102e;
          }

          .cms-gallery-preview h1 {
            margin: 0;
            color: #14171b;
            font-family: "Barlow Condensed", Barlow, ui-sans-serif, system-ui, sans-serif;
            font-size: clamp(2.8rem, 7vw, 4.2rem);
            font-weight: 700;
            letter-spacing: 0.01em;
            line-height: 0.95;
          }

          .cms-gallery-preview__lead {
            max-width: 640px;
            margin: 0.9rem 0 2.25rem;
            color: #5a6470;
            font-size: 1.05rem;
            font-weight: 500;
          }

          .cms-gallery-preview .gallery-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.5rem;
          }

          .cms-gallery-preview .album-card {
            position: relative;
            display: block;
            overflow: hidden;
            border-radius: 6px;
            background: #0f1114;
            transition:
              transform 280ms cubic-bezier(0.2, 0.8, 0.2, 1),
              box-shadow 280ms cubic-bezier(0.22, 0.61, 0.36, 1);
          }

          .cms-gallery-preview .album-card__image {
            width: 100%;
            height: 260px;
            object-fit: cover;
            transition: transform 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
          }

          .cms-gallery-preview .album-card__caption {
            position: absolute;
            inset: auto 0 0;
            padding: 2rem 0.9rem 0.85rem;
            background: linear-gradient(transparent, rgba(15, 17, 20, 0.86));
            color: #ffffff;
            font-weight: 600;
            line-height: 1.25;
          }

          .cms-gallery-preview .album-card__caption small {
            display: block;
            margin-top: 0.2rem;
            color: #c6cdd4;
            font-weight: 500;
            line-height: 1.35;
          }

          @media (hover: hover) and (pointer: fine) {
            .cms-gallery-preview .album-card:hover {
              box-shadow: 0 18px 44px rgba(15, 23, 32, 0.13);
              transform: translateY(-3px);
            }

            .cms-gallery-preview .album-card:hover .album-card__image {
              transform: scale(1.04);
            }
          }

          @media (max-width: 860px) {
            .cms-gallery-preview .gallery-grid {
              grid-template-columns: repeat(2, minmax(0, 1fr));
            }
          }

          @media (max-width: 620px) {
            .cms-gallery-preview__inner {
              padding: 30px 18px 52px;
            }

            .cms-gallery-preview .gallery-grid {
              grid-template-columns: 1fr;
            }

            .cms-gallery-preview .album-card__image {
              height: 230px;
            }
          }
        `,
        { raw: true },
      );

      CMS.registerPreviewTemplate('news', ({ entry, widgetFor }: NewsPreviewProps) => {
        const title = getField(entry, 'title', 'Titulek aktuality');
        const excerpt = getField(entry, 'excerpt', 'Krátký perex aktuality se zobrazí pod titulkem stejně jako na webu.');
        const category = getField(entry, 'category', 'Aktuality');
        const image = getImageUrl(getField(entry, 'image'));
        const date = formatDate(entry.getIn(['data', 'date']));

        return h('article', { className: 'cms-news-preview' }, [
          h('div', { className: 'cms-news-preview__inner', key: 'inner' }, [
            h('div', { className: 'cms-news-preview__breadcrumbs', key: 'breadcrumbs' }, [
              'Úvod / Aktuality / ',
              h('span', { key: 'current' }, title),
            ]),
            h('div', { className: 'cms-news-preview__meta', key: 'meta' }, [
              h('span', { className: 'cms-news-preview__tag', key: 'tag' }, category),
              h('time', { key: 'time' }, date),
            ]),
            h('h1', { key: 'title' }, title),
            h('p', { className: 'cms-news-preview__lead', key: 'excerpt' }, excerpt),
            h('img', { className: 'cms-news-preview__image', src: image, alt: title, key: 'image' }),
            h('span', { className: 'cms-news-preview__caption', key: 'caption' }, 'Foto z klubového archivu HC Říčany.'),
            h('div', { className: 'cms-news-preview__body', key: 'body' }, widgetFor('body')),
            h('div', { className: 'cms-news-preview__info', key: 'info' }, [
              h('h2', { key: 'info-title' }, 'Praktické informace'),
              h('div', { className: 'cms-news-preview__info-grid', key: 'info-grid' }, [
                h('span', { key: 'when' }, [h('strong', { key: 'when-label' }, 'Kdy: '), 'dle aktuálního rozpisu klubu']),
                h('span', { key: 'where' }, [h('strong', { key: 'where-label' }, 'Kde: '), 'COM-SYS ICE ARENA, Říčany']),
                h('span', { key: 'gear' }, [h('strong', { key: 'gear-label' }, 'S sebou: '), 'teplé oblečení a rukavice']),
                h('span', { key: 'contact' }, [h('strong', { key: 'contact-label' }, 'Kontakt: '), 'nabor@hcricany.cz']),
              ]),
            ]),
          ]),
        ]);
      });

      CMS.registerPreviewTemplate('gallery', ({ entry }: GalleryPreviewProps) => {
        const photos = getListItems(entry.getIn(['data', 'photos']));
        const title = getField(entry, 'title', 'Název alba');
        const date = formatAlbumDate(entry.getIn(['data', 'date']));
        const coverImage = getField(entry, 'coverImage') || getRecordString(photos[0], 'image');
        const image = getImageUrl(coverImage);
        const meta = `${date} · ${formatPhotoCount(photos.length)}`;

        return h('article', { className: 'cms-gallery-preview' }, [
          h('div', { className: 'cms-gallery-preview__inner', key: 'inner' }, [
            h('p', { className: 'cms-gallery-preview__eyebrow', key: 'eyebrow' }, 'Fotogalerie'),
            h('h1', { key: 'title' }, 'Fotogalerie'),
            h(
              'p',
              { className: 'cms-gallery-preview__lead', key: 'lead' },
              'Momentky z tréninků, náborových akcí, turnajů a klubového života.',
            ),
            h('div', { className: 'gallery-grid gallery-grid--page', key: 'grid' }, [
              h('a', { className: 'album-card', href: '/fotogalerie/', key: 'card' }, [
                h('img', { className: 'album-card__image', src: image, alt: title, key: 'image' }),
                h('span', { className: 'album-card__caption', key: 'caption' }, [
                  title,
                  h('small', { key: 'meta' }, meta),
                ]),
              ]),
            ]),
          ]),
        ]);
      });

      const seedDemoContent = () => {
        if (demoWindow.repoFiles && Object.keys(demoWindow.repoFiles).length > 0) return;
        demoWindow.repoFiles = {
          aktuality: {
            'tyden-hokeje-2026.md': {
              path: 'aktuality/tyden-hokeje-2026.md',
              content: `---
title: "Týden hokeje 2026 se blíží"
slug: "tyden-hokeje-2026"
date: "2026-09-23T16:00:00.000Z"
excerpt: "Přijďte si vyzkoušet první hokejový trénink v COM-SYS ICE ARENĚ."
image: "/images/navrh01/ricany_kids.jpg"
category: "Nábor"
published: true
---

Ukázková aktualita pro demo redakčního systému. V produkční verzi by se po uložení vytvořil commit v GitHub repozitáři a web by se znovu nasadil.`,
            },
            'rozpis-pripravneho-obdobi.md': {
              path: 'aktuality/rozpis-pripravneho-obdobi.md',
              content: `---
title: "Rozpis přípravného období"
slug: "rozpis-pripravneho-obdobi"
date: "2026-08-10T08:00:00.000Z"
excerpt: "Tréninky a klubové akce pro začátek sezóny jsou připravené."
image: "/images/navrh01/ricany_boy.jpg"
category: "Mládež"
published: true
---

Ukázkový obsah pro náhled práce s aktualitami.`,
            },
          },
          fotogalerie: {
            'tyden-hokeje.md': {
              path: 'fotogalerie/tyden-hokeje.md',
              content: `---
title: "Týden hokeje v COM-SYS ICE ARENĚ"
slug: "tyden-hokeje"
date: "2026-09-23T16:00:00.000Z"
coverImage: "/images/navrh01/ricany_kids.jpg"
description: "Ukázkové album pro předvedení správy fotogalerie."
photos:
  - image: "/images/navrh01/ricany_kids.jpg"
    caption: "Společný trénink na ledě"
  - image: "/images/navrh01/ricany_girl.jpg"
    caption: "První kroky na bruslích"
---
`,
            },
          },
        };
      };

      const startCms = () => {
        if (cmsStarted) return;
        cmsStarted = true;
        if (!login) return;
        login.hidden = true;
        cmsRoot?.setAttribute('hidden', '');
        document.body.classList.add('is-cms-active');
        seedDemoContent();
        CMS.init();
        window.scrollTo({ top: 0, left: 0 });
      };

      if (sessionStorage.getItem(sessionKey) === '1') {
        startCms();
      }

      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const honeypot = String(data.get('website') ?? '').trim();

        if (honeypot) {
          if (error) error.hidden = false;
          return;
        }

        if (error) error.hidden = true;
        sessionStorage.setItem(sessionKey, '1');
        startCms();
      });
    </script>
