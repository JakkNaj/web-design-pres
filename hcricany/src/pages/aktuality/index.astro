---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/site/PageHero.astro';
import NewsCard from '../../components/site/NewsCard.astro';

const [newsCollection, settingsCollection] = await Promise.all([
  getCollection('news', ({ data }) => data.published),
  getCollection('settings'),
]);

const news = newsCollection.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = news[0];
const rest = news.slice(1);
const settings = settingsCollection[0].data;
const categories = ['Vše', 'Nábor', 'Turnaje', 'Tréninky', 'Klub', 'Pro rodiče'];
---

<BaseLayout title="Aktuality | HC Říčany" description="Novinky z tréninků, turnajů, náborových akcí a života HC Říčany." settings={settings} active="Aktuality">
  <PageHero title="Aktuality z klubu" description="Novinky z tréninků, turnajů, náborových akcí a života HC Říčany." active="Aktuality">
    <div class="filter-row">
      {categories.map((category, index) => <a class:list={{ 'is-active': index === 0 }} href="/aktuality/">{category}</a>)}
    </div>
  </PageHero>

  <section class="section section--white">
    <div class="site-shell">
      {featured && (
        <div style="margin-bottom: 2.5rem">
          <NewsCard item={featured} featured />
        </div>
      )}
      <div class="news-list-grid">
        {rest.map((item) => <NewsCard item={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
